# Example nginx reverse proxy: terminate TLS publicly, proxy WS to the
# policy server bound on localhost. The server itself does not implement
# TLS; for wss:// run it behind nginx / Caddy / a cloud load balancer.
#
# Required: an HTTPS certificate for your_domain (e.g. via certbot).

upstream policy_server {
    server 127.0.0.1:8000;
    keepalive 4;
}

server {
    listen 443 ssl http2;
    server_name your_domain;

    ssl_certificate     /etc/letsencrypt/live/your_domain/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your_domain/privkey.pem;

    # Hard cap on request body — match server.max_message_size.
    client_max_body_size 32m;

    location / {
        proxy_pass         http://policy_server;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade            $http_upgrade;
        proxy_set_header   Connection         "upgrade";
        proxy_set_header   Host               $host;
        proxy_set_header   X-Real-IP          $remote_addr;
        proxy_set_header   X-Forwarded-For    $proxy_add_x_forwarded_for;

        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
    }

    location = /healthz {
        proxy_pass http://policy_server/healthz;
        access_log off;
    }
}

server {
    listen 80;
    server_name your_domain;
    return 301 https://$host$request_uri;
}
